# Required: base URL of the 9router dashboard (no trailing slash, no path)
BASE_URL=http://localhost:20128

# Required: value of the auth_token cookie from your dashboard session
AUTH_TOKEN=

# Optional: path to the refresh-tokens list (one token per line)
TOKENS_FILE=kiro-out/kiro-refresh-tokens.txt

# Optional: seconds to wait between requests (default 1)
DELAY_SECONDS=1

# Optional: skip TLS verification (for self-signed dashboards). default false
INSECURE=false
